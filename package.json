{
  "name": "scrimba-lesson-engine",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npx tsx watch --env-file=.env server/index.ts",
    "dev:client": "cd client && npx vite",
    "build": "cd server && npm install && cd ../client && npm install && npm run build",
    "start": "tsx server/index.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "tsx": "^4.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
